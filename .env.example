# =============================================================
# LOCAL PROFILE (.env.local)
# =============================================================
# Stable local defaults (no tunnel dependency)
# VITE_PUBLIC_APP_ORIGIN=http://localhost:5173
# VITE_API_ORIGIN=http://localhost:8080
# Optional: only set when Spring backend really exposes a websocket endpoint.
# VITE_HOADON_WS_URL=ws://localhost:8080/ws/hoa-don
# VITE_HOADON_WS_AUTO=false

# =============================================================
# PRODUCTION PROFILE (.env.production)
# =============================================================
# Replace with real domains before production build
# VITE_PUBLIC_APP_ORIGIN=https://app.yourdomain.com
# VITE_API_ORIGIN=https://api.yourdomain.com
# VITE_API_BASE_URL=https://api.yourdomain.com/api
# Optional Node backend used by some admin/mail/realtime features
# VITE_NODE_BACKEND_URL=https://node.yourdomain.com
# Optional: websocket URL for realtime invoice channel
# VITE_HOADON_WS_URL=wss://node.yourdomain.com/ws/hoa-don
# VITE_HOADON_WS_AUTO=false

# Set actual values below for your active profile file.
VITE_PUBLIC_APP_ORIGIN=
VITE_API_ORIGIN=
VITE_API_BASE_URL=
VITE_NODE_BACKEND_URL=
VITE_HOADON_WS_URL=
VITE_HOADON_WS_AUTO=
