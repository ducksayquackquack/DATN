SET NOCOUNT ON;
SET XACT_ABORT ON;

BEGIN TRAN;

-- Ensure required colors exist.
IF NOT EXISTS (SELECT 1 FROM dbo.MauSac WHERE tenMau COLLATE Vietnamese_100_CI_AI = N'Nâu' COLLATE Vietnamese_100_CI_AI)
    INSERT INTO dbo.MauSac (maMau, tenMau) VALUES (N'MS_NAU', N'Nâu');

IF NOT EXISTS (SELECT 1 FROM dbo.MauSac WHERE tenMau COLLATE Vietnamese_100_CI_AI = N'Đỏ' COLLATE Vietnamese_100_CI_AI)
    INSERT INTO dbo.MauSac (maMau, tenMau) VALUES (N'MS_DO', N'Đỏ');

IF NOT EXISTS (SELECT 1 FROM dbo.MauSac WHERE tenMau COLLATE Vietnamese_100_CI_AI = N'Xanh dương' COLLATE Vietnamese_100_CI_AI)
    INSERT INTO dbo.MauSac (maMau, tenMau) VALUES (N'MS_XANH_DUONG', N'Xanh dương');

IF NOT EXISTS (SELECT 1 FROM dbo.MauSac WHERE tenMau COLLATE Vietnamese_100_CI_AI = N'Đen' COLLATE Vietnamese_100_CI_AI)
    INSERT INTO dbo.MauSac (maMau, tenMau) VALUES (N'MS_DEN', N'Đen');

IF NOT EXISTS (SELECT 1 FROM dbo.MauSac WHERE tenMau COLLATE Vietnamese_100_CI_AI = N'Kem' COLLATE Vietnamese_100_CI_AI)
    INSERT INTO dbo.MauSac (maMau, tenMau) VALUES (N'MS_KEM', N'Kem');

IF NOT EXISTS (SELECT 1 FROM dbo.MauSac WHERE tenMau COLLATE Vietnamese_100_CI_AI = N'Trắng' COLLATE Vietnamese_100_CI_AI)
    INSERT INTO dbo.MauSac (maMau, tenMau) VALUES (N'MS_TRANG', N'Trắng');

IF NOT EXISTS (SELECT 1 FROM dbo.MauSac WHERE tenMau COLLATE Vietnamese_100_CI_AI = N'Vàng' COLLATE Vietnamese_100_CI_AI)
    INSERT INTO dbo.MauSac (maMau, tenMau) VALUES (N'MS_VANG', N'Vàng');

DECLARE @colorBrown INT = (SELECT TOP 1 id FROM dbo.MauSac WHERE tenMau COLLATE Vietnamese_100_CI_AI = N'Nâu' COLLATE Vietnamese_100_CI_AI ORDER BY id);
DECLARE @colorRed INT = (SELECT TOP 1 id FROM dbo.MauSac WHERE tenMau COLLATE Vietnamese_100_CI_AI = N'Đỏ' COLLATE Vietnamese_100_CI_AI ORDER BY id);
DECLARE @colorBlue INT = (SELECT TOP 1 id FROM dbo.MauSac WHERE tenMau COLLATE Vietnamese_100_CI_AI = N'Xanh dương' COLLATE Vietnamese_100_CI_AI ORDER BY id);
DECLARE @colorBlack INT = (SELECT TOP 1 id FROM dbo.MauSac WHERE tenMau COLLATE Vietnamese_100_CI_AI = N'Đen' COLLATE Vietnamese_100_CI_AI ORDER BY id);
DECLARE @colorKem INT = (SELECT TOP 1 id FROM dbo.MauSac WHERE tenMau COLLATE Vietnamese_100_CI_AI = N'Kem' COLLATE Vietnamese_100_CI_AI ORDER BY id);
DECLARE @colorWhite INT = (SELECT TOP 1 id FROM dbo.MauSac WHERE tenMau COLLATE Vietnamese_100_CI_AI = N'Trắng' COLLATE Vietnamese_100_CI_AI ORDER BY id);
DECLARE @colorYellow INT = (SELECT TOP 1 id FROM dbo.MauSac WHERE tenMau COLLATE Vietnamese_100_CI_AI = N'Vàng' COLLATE Vietnamese_100_CI_AI ORDER BY id);

-- Resolve core product ids.
DECLARE @sp001 INT = (SELECT TOP 1 id FROM dbo.SanPham WHERE maSanPham = N'SP001' ORDER BY id);
DECLARE @sp002 INT = (SELECT TOP 1 id FROM dbo.SanPham WHERE maSanPham = N'SP002' ORDER BY id);
DECLARE @sp003 INT = (SELECT TOP 1 id FROM dbo.SanPham WHERE maSanPham = N'SP003' ORDER BY id);
DECLARE @sp004 INT = (SELECT TOP 1 id FROM dbo.SanPham WHERE maSanPham = N'SP004' ORDER BY id);
DECLARE @sp005 INT = (SELECT TOP 1 id FROM dbo.SanPham WHERE maSanPham = N'SP005' ORDER BY id);
DECLARE @sp006 INT = (SELECT TOP 1 id FROM dbo.SanPham WHERE maSanPham = N'SP006' ORDER BY id);
DECLARE @sp007 INT = (SELECT TOP 1 id FROM dbo.SanPham WHERE maSanPham = N'SP007' ORDER BY id);
DECLARE @sp008 INT = (SELECT TOP 1 id FROM dbo.SanPham WHERE maSanPham = N'SP008' ORDER BY id);
DECLARE @sp009 INT = (SELECT TOP 1 id FROM dbo.SanPham WHERE maSanPham = N'SP009' ORDER BY id);
DECLARE @sp010 INT = (SELECT TOP 1 id FROM dbo.SanPham WHERE maSanPham = N'SP010' ORDER BY id);
DECLARE @sp011 INT = (SELECT TOP 1 id FROM dbo.SanPham WHERE maSanPham = N'SP011' ORDER BY id);
DECLARE @sp015 INT = (SELECT TOP 1 id FROM dbo.SanPham WHERE maSanPham = N'SP015' ORDER BY id);
DECLARE @sp017 INT = (SELECT TOP 1 id FROM dbo.SanPham WHERE maSanPham = N'SP017' ORDER BY id);

-- Keep official product names.
IF @sp001 IS NOT NULL UPDATE dbo.SanPham SET tenSanPham = N'Bomber da lộn DirtyWave' WHERE id = @sp001;
IF @sp002 IS NOT NULL UPDATE dbo.SanPham SET tenSanPham = N'Bomber dáng lửng DirtyWave' WHERE id = @sp002;
IF @sp004 IS NOT NULL UPDATE dbo.SanPham SET tenSanPham = N'Bomber cotton nhẹ DirtyWave' WHERE id = @sp004;
IF @sp005 IS NOT NULL UPDATE dbo.SanPham SET tenSanPham = N'Hoodie dáng hộp DirtyWave' WHERE id = @sp005;
IF @sp006 IS NOT NULL UPDATE dbo.SanPham SET tenSanPham = N'Hoodie in hình DirtyWave' WHERE id = @sp006;
IF @sp007 IS NOT NULL UPDATE dbo.SanPham SET tenSanPham = N'Hoodie kéo khoá DirtyWave' WHERE id = @sp007;
IF @sp008 IS NOT NULL UPDATE dbo.SanPham SET tenSanPham = N'Coach cách nhiệt DirtyWave' WHERE id = @sp008;
IF @sp009 IS NOT NULL UPDATE dbo.SanPham SET tenSanPham = N'Coach da trơn DirtyWave' WHERE id = @sp009;
IF @sp011 IS NOT NULL UPDATE dbo.SanPham SET tenSanPham = N'Coach lông cừu DirtyWave' WHERE id = @sp011;
IF @sp015 IS NOT NULL UPDATE dbo.SanPham SET tenSanPham = N'Coach Leopard DirtyWave' WHERE id = @sp015;
IF @sp017 IS NOT NULL UPDATE dbo.SanPham SET tenSanPham = N'Coach Tiger Stripe DirtyWave' WHERE id = @sp017;

-- Combine SP003 into SP002 (Bomber dáng lửng DirtyWave with red + blue).
IF @sp002 IS NOT NULL
BEGIN
    UPDATE dbo.SanPhamChiTiet
    SET idMauSac = @colorRed
    WHERE idSanPham = @sp002;

    IF @sp003 IS NOT NULL AND @sp003 <> @sp002
    BEGIN
        UPDATE dbo.SanPhamChiTiet
        SET idSanPham = @sp002,
            idMauSac = @colorBlue
        WHERE idSanPham = @sp003;

        UPDATE dbo.AnhMinhHoa
        SET maAnh = REPLACE(maAnh, N'SP003', N'SP002')
        WHERE maAnh LIKE N'%SP003%';

        DELETE FROM dbo.SanPham
        WHERE id = @sp003;
    END

    -- Re-apply deterministic colors so rerun stays stable.
    UPDATE spct
    SET idMauSac = CASE
        WHEN UPPER(ISNULL(spct.ma, N'')) LIKE N'SPCT003%' THEN @colorBlue
        ELSE @colorRed
    END
    FROM dbo.SanPhamChiTiet spct
    WHERE spct.idSanPham = @sp002;
END

-- Combine SP010 into SP009 (Coach da trơn DirtyWave with kem + nâu).
IF @sp009 IS NOT NULL
BEGIN
    UPDATE dbo.SanPhamChiTiet
    SET idMauSac = @colorKem
    WHERE idSanPham = @sp009;

    IF @sp010 IS NOT NULL AND @sp010 <> @sp009
    BEGIN
        UPDATE dbo.SanPhamChiTiet
        SET idSanPham = @sp009,
            idMauSac = @colorBrown
        WHERE idSanPham = @sp010;

        UPDATE dbo.AnhMinhHoa
        SET maAnh = REPLACE(maAnh, N'SP010', N'SP009')
        WHERE maAnh LIKE N'%SP010%';

        DELETE FROM dbo.SanPham
        WHERE id = @sp010;
    END

    -- Re-apply deterministic colors so rerun stays stable.
    UPDATE spct
    SET idMauSac = CASE
        WHEN UPPER(ISNULL(spct.ma, N'')) LIKE N'SPCT010%' THEN @colorBrown
        ELSE @colorKem
    END
    FROM dbo.SanPhamChiTiet spct
    WHERE spct.idSanPham = @sp009;
END

-- Apply requested single-color products.
IF @sp001 IS NOT NULL UPDATE dbo.SanPhamChiTiet SET idMauSac = @colorBrown WHERE idSanPham = @sp001;
IF @sp004 IS NOT NULL UPDATE dbo.SanPhamChiTiet SET idMauSac = @colorBlack WHERE idSanPham = @sp004;
IF @sp005 IS NOT NULL UPDATE dbo.SanPhamChiTiet SET idMauSac = @colorBlack WHERE idSanPham = @sp005;
IF @sp006 IS NOT NULL UPDATE dbo.SanPhamChiTiet SET idMauSac = @colorBlack WHERE idSanPham = @sp006;
IF @sp007 IS NOT NULL UPDATE dbo.SanPhamChiTiet SET idMauSac = @colorBlue WHERE idSanPham = @sp007;
IF @sp008 IS NOT NULL UPDATE dbo.SanPhamChiTiet SET idMauSac = @colorBrown WHERE idSanPham = @sp008;
IF @sp011 IS NOT NULL UPDATE dbo.SanPhamChiTiet SET idMauSac = @colorWhite WHERE idSanPham = @sp011;
IF @sp015 IS NOT NULL UPDATE dbo.SanPhamChiTiet SET idMauSac = @colorYellow WHERE idSanPham = @sp015;
IF @sp017 IS NOT NULL UPDATE dbo.SanPhamChiTiet SET idMauSac = @colorWhite WHERE idSanPham = @sp017;

-- Cleanup: if old products still exist by name but not wanted, remove them.
DELETE sp
FROM dbo.SanPham sp
WHERE sp.maSanPham IN (N'SP003', N'SP010')
  AND NOT EXISTS (SELECT 1 FROM dbo.SanPhamChiTiet c WHERE c.idSanPham = sp.id);

COMMIT TRAN;
