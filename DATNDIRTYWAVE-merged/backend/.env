# SMTP config for employee/customer emails (Node.js backend)
# If empty, the app auto-creates a free Ethereal test account to preview emails
# To use real email, fill these in
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
LOOKUP_MAIL_FROM=

# For Gmail: use app password (not your real password)
# 1. Enable 2-Step Verification: https://myaccount.google.com/security
# 2. Create app password: https://myaccount.google.com/apppasswords
# Example config:
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=16-character-app-password
# LOOKUP_MAIL_FROM="Your Name <your-email@gmail.com>"
