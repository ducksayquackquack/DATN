# SMTP config for employee/order emails (preferred keys)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
LOOKUP_MAIL_FROM="DirtyWave <your-email@gmail.com>"

# Optional aliases also supported by backend/server.js
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM="DirtyWave <your-email@gmail.com>"

# Optional flags already used in backend
AUTO_SEED_CAMPAIGN_PRODUCTS=true
AUTO_SEED_CAMPAIGN_ID=0
AUTO_SEED_CAMPAIGN_CODE=KM006
AUTO_SEED_PRODUCT_COUNT=5
